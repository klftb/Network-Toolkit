{
  "name": "network-toolkit",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:esbuild --external:lightningcss --external:tsx --external:sharp --external:tailwindcss --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "npm run build && electron .",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win"
  },
  "build": {
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "appId": "com.network.toolkit",
    "productName": "Network Toolkit",
    "icon": "build/icon.png",
    "asar": true,
    "compression": "maximum",
    "removePackageScripts": true,
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json",
      "build/icon.png",
      "build/icon.ico",
      "!node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      },
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Network Toolkit"
    }
  },
  "overrides": {
    "react-simple-maps": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "node-domexception": "file:patches/node-domexception"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "basic-ftp": "^6.0.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "iconv-lite": "^0.7.2",
    "kdbxweb": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "node-wifi": "^2.0.16",
    "nodejs-traceroute": "^2.0.1",
    "ping": "^1.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.1",
    "ssh2-sftp-client": "^12.1.1",
    "tailwind-merge": "^3.6.0",
    "tftp": "^0.1.2",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "whois": "^2.16.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/ping": "^0.4.4",
    "@types/react-simple-maps": "^3.0.6",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
